{
  "name": "civicvault",
  "version": "1.0.0",
  "description": "Local-First, Air-Gapped Legal Intelligence System",
  "main": "electron/main.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "@langchain/core": "^1.1.28",
    "@langchain/ollama": "^1.2.4",
    "@langchain/textsplitters": "^1.0.1",
    "better-sqlite3": "^12.6.2",
    "langchain": "^1.2.27",
    "minisearch": "^7.2.0",
    "pdf-parse": "^1.1.1",
    "pdf-to-image-generator": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.1.1",
    "systeminformation": "^5.31.1",
    "tesseract.js": "^7.0.0",
    "vectordb": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.civicvault.app",
    "productName": "CivicVault",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
